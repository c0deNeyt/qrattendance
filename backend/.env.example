# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=qr_attendance

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRES_IN=8h

# ── App ──────────────────────────────────────────────────────
# Public base URL used inside QR codes (no trailing slash)
BASE_URL=http://localhost:5000

# Optional: QR token expiry in days (0 = never)
QR_EXPIRES_DAYS=0

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
